{
  "name": "@cloudflare/modules",
  "description": "DSPy-esque typed modules, traces, artifacts, and shell-backed RLMs for Cloudflare Agents",
  "keywords": [
    "cloudflare",
    "agents",
    "ai",
    "modules",
    "dspy"
  ],
  "type": "module",
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "directory": "packages/modules",
    "type": "git",
    "url": "git+https://github.com/cloudflare/agents.git"
  },
  "author": "Cloudflare Inc.",
  "bugs": {
    "url": "https://github.com/cloudflare/agents/issues"
  },
  "devDependencies": {
    "@cloudflare/shell": "*",
    "ai": "^6.0.141",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@cloudflare/shell": ">=0.2.0 <1.0.0",
    "agents": ">=0.7.0 <1.0.0",
    "ai": "^6.0.0",
    "zod": "^4.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./agents": {
      "types": "./dist/agents.d.ts",
      "import": "./dist/agents.js"
    },
    "./workers": {
      "types": "./dist/workers.d.ts",
      "import": "./dist/workers.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsx ./scripts/build.ts",
    "test": "vitest --run",
    "test:workers": "vitest --run",
    "test:e2e": "npx playwright test --config e2e/playwright.config.ts"
  }
}
